rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Bloqueio padrão de segurança global
    match /{document=**} {
      allow read, write: if false;
    }

    // Regras para a Coleção de Usuários
    // Cada usuário lê e grava apenas seu próprio perfil; o Administrador Geral ('LGoyJO3HjsN2iSmWiIPhtILMYPu1') tem permissão total de leitura e escrita.
    match /users/{userId} {
      allow read, write: if request.auth != null && (
        request.auth.uid == userId || 
        request.auth.uid == "LGoyJO3HjsN2iSmWiIPhtILMYPu1"
      );

      // Regras para subcoleção de Investimentos de cada usuário
      match /investments/{investmentId} {
        allow read, write: if request.auth != null && (
          request.auth.uid == userId || 
          request.auth.uid == "LGoyJO3HjsN2iSmWiIPhtILMYPu1"
        );
      }

      // Regras para subcoleção de Transações (Depósitos/Levantamentos) de cada usuário
      match /transactions/{transactionId} {
        allow read, write: if request.auth != null && (
          request.auth.uid == userId || 
          request.auth.uid == "LGoyJO3HjsN2iSmWiIPhtILMYPu1"
        );
      }
    }

    // Regras de Configurações Globais (Como Bloqueio Global de Operações)
    match /globals/{globalId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (
        request.auth.uid == "LGoyJO3HjsN2iSmWiIPhtILMYPu1"
      );
    }
  }
}
